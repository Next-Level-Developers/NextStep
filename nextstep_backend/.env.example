# ──────────────────────────────────────────────────────────────
# NextStep — FastAPI Environment Configuration
# Copy this file to .env and fill in all values.
# Do NOT commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-here
APP_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (AWS RDS PostgreSQL) ──────────────────────────────
DB_HOST=djangodb.cvmekawm0tyq.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=nextstep_user
DB_PASSWORD=Pushkar141

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AWS S3 ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET_NAME=nextstep-assets
AWS_S3_REGION=ap-south-1

# ── Firebase Admin SDK ─────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=nextstep-d7965

# ── Anthropic Claude AI ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1000
AI_FREE_DAILY_MESSAGE_LIMIT=5

# ── Razorpay ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Redis (Celery broker + caching) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080,https://nextstep.app
