# ──────────────────────────────────────────────────────────────
# NextStep — FastAPI Environment Configuration
# ──────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-64-char-random-string
APP_DEBUG=True
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# ── Database (AWS RDS PostgreSQL) ──────────────────────────────
DB_HOST=djangodb.cvmekawm0tyq.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=Pushkar141
DB_SSLMODE=verify-full
DB_SSLROOTCERT=global-bundle.pem

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AWS S3 ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET_NAME=nextstep-assets
AWS_S3_REGION=ap-south-1

# ── Firebase Admin SDK ─────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=

# ── Anthropic Claude AI ────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1000
AI_FREE_DAILY_MESSAGE_LIMIT=5

# ── Razorpay ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_SECRET=CHANGE_ME

# ── Redis (Celery broker + caching) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8080","https://nextstep.app"]
